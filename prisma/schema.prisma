// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====
// Enums
// =====
enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum EnvironmentType {
  DEVELOPMENT
  TESTING
  STAGING
  PRODUCTION
}

enum EnvironmentStatus {
  ACTIVE
  LOCKED
  ARCHIVED
  DISABLED
}

// ============================
// Identity & Access Management
// ============================
model User {
  id                 BigInt     @id @default(autoincrement()) @db.BigInt
  publicId           String     @unique @default(uuid()) @map("public_id") @db.Uuid
  email              String     @unique @db.VarChar(255)
  passwordHash       String     @map("password_hash") @db.VarChar(255)
  displayName        String     @map("display_name") @db.VarChar(255)
  isEmailVerified    Boolean    @default(false) @map("is_email_verified")
  status             UserStatus @default(PENDING_VERIFICATION)
  failedLoginAttempt Int?       @map("failed_login_attempt")
  lastLoggedIn       DateTime?  @map("last_logged_in")
  lockedUntil        DateTime?  @map("locked_until")
  tokenVersion       Int        @default(0) @map("token_version")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @default(now()) @map("updated_at")

  memberships        OrganizationMember[] @relation("MembershipUser")
  createdMemberships OrganizationMember[] @relation("MemberCreatedBy")
  updatedMemberships OrganizationMember[] @relation("MemberUpdatedBy")

  createdOrganizations Organization[] @relation("OrgCreatedBy")
  updatedOrganizations Organization[] @relation("OrgUpdatedBy")

  createdProjects Project[] @relation("ProjectCreatedBy")
  updatedProjects Project[] @relation("ProjectUpdatedBy")

  createdEnvironments Environment[] @relation("EnvCreatedBy")
  updatedEnvironments Environment[] @relation("EnvUpdatedBy")

  membershipUpdateHistories OrganizationMemberHistory[]
  refreshTokens             RefreshToken[]
  auditLogs                 AuditLog[]      @relation("AuditLogActor")
  exceptionLogs             ExceptionLog[]  @relation("ExceptionLogActor")

  @@index([publicId, email, status])
  @@map("users")
}

model Organization {
  id        BigInt             @id @default(autoincrement()) @db.BigInt
  publicId  String             @unique @default(uuid()) @map("public_id") @db.Uuid
  slug      String             @unique @default("") @db.VarChar(255)
  name      String             @default("") @db.VarChar(255)
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  createdBy BigInt             @map("created_by") @db.BigInt
  updatedAt DateTime           @default(now()) @map("updated_at")
  updatedBy BigInt             @map("updated_by") @db.BigInt
  deletedAt DateTime?          @map("deleted_at")

  createdByUser User @relation("OrgCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User @relation("OrgUpdatedBy", fields: [updatedBy], references: [id])

  members OrganizationMember[]
  projects Project[]
  auditLogs AuditLog[]
  exceptionLogs ExceptionLog[]

  @@index([publicId, slug, status])
  @@map("organizations")
}

model OrganizationMember {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId BigInt       @map("organization_id") @db.BigInt
  userId         BigInt       @map("user_id") @db.BigInt
  roleId         BigInt       @map("role_id") @db.BigInt
  status         MemberStatus @default(PENDING)
  joinedAt       DateTime?    @map("joined_at")
  removedAt      DateTime?    @map("removed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  createdBy      BigInt       @map("created_by") @db.BigInt
  updatedAt      DateTime     @default(now()) @map("updated_at")
  updatedBy      BigInt       @map("updated_by") @db.BigInt

  organization  Organization     @relation(fields: [organizationId], references: [id])
  role          OrganizationRole @relation(fields: [roleId], references: [id])
  member        User             @relation("MembershipUser", fields: [userId], references: [id])
  createdByUser User             @relation("MemberCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User             @relation("MemberUpdatedBy", fields: [updatedBy], references: [id])

  membershipHistories OrganizationMemberHistory[]

  @@unique([organizationId, userId])
  @@index([organizationId, userId, roleId])
  @@map("organization_members")
}

model OrganizationMemberHistory {
  id             BigInt   @id @default(autoincrement()) @db.BigInt
  memberId       BigInt   @map("member_id") @db.BigInt
  previousDetail Json?    @default("{}") @map("previous_detail") @db.JsonB
  detail         Json     @default("{}") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      BigInt   @map("created_by")

  memberDetail  OrganizationMember @relation(fields: [memberId], references: [id])
  createdByUser User               @relation(fields: [createdBy], references: [id])

  @@map("organization_member_histories")
}

model OrganizationRole {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  name      String   @unique @default("") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  organizationMembers         OrganizationMember[]
  organizationRolePermissions OrganizationRolePermission[]

  @@map("organization_roles")
}

model Permission {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  code        String   @unique @default("") @db.VarChar(255)
  name        String   @default("") @db.VarChar(255)
  description String   @default("") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  organizationRolePermissions OrganizationRolePermission[]

  @@map("permissions")
}

model OrganizationRolePermission {
  id           BigInt   @id @default(autoincrement()) @db.BigInt
  roleId       BigInt   @map("role_id") @db.BigInt
  permissionId BigInt   @map("permission_id") @db.BigInt
  createdAt    DateTime @default(now()) @map("created_at")

  role       OrganizationRole @relation(fields: [roleId], references: [id])
  permission Permission       @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId, permissionId])
  @@map("organization_role_permissions")
}

// =======
// Project
// =======
model Project {
  id             BigInt        @id @default(autoincrement()) @db.BigInt
  publicId       String        @unique @default(uuid()) @map("public_id") @db.Uuid
  organizationId BigInt        @map("organization_id") @db.BigInt
  name           String        @default("") @db.VarChar(255)
  slug           String        @default("") @db.VarChar(255)
  description    String        @default("") @db.Text
  status         ProjectStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  createdBy      BigInt        @map("created_by") @db.BigInt
  updatedAt      DateTime      @default(now()) @map("updated_at")
  updatedBy      BigInt        @map("updated_by") @db.BigInt
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  createdByUser User             @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User             @relation("ProjectUpdatedBy", fields: [updatedBy], references: [id])
  environments  Environment[]
  auditLogs     AuditLog[]

  @@unique([organizationId, slug])
  @@index([publicId, organizationId, status])
  @@map("projects")
}

// ============
// Environment
// ============
model Environment {
  id              BigInt           @id @default(autoincrement()) @db.BigInt
  publicId        String           @unique @default(uuid()) @map("public_id") @db.Uuid
  projectId       BigInt           @map("project_id") @db.BigInt
  name            String           @default("") @db.VarChar(255)
  type            EnvironmentType  @default(DEVELOPMENT)
  status          EnvironmentStatus @default(ACTIVE)
  protectionLevel Int              @default(0) @map("protection_level")
  createdAt       DateTime         @default(now()) @map("created_at")
  createdBy       BigInt           @map("created_by") @db.BigInt
  updatedAt       DateTime         @default(now()) @map("updated_at")
  updatedBy       BigInt           @map("updated_by") @db.BigInt
  deletedAt       DateTime?        @map("deleted_at")

  project       Project       @relation(fields: [projectId], references: [id])
  createdByUser User          @relation("EnvCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User          @relation("EnvUpdatedBy", fields: [updatedBy], references: [id])
  auditLogs     AuditLog[]

  @@unique([projectId, name])
  @@index([publicId, projectId, status])
  @@map("environments")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  userId    BigInt    @map("user_id") @db.BigInt
  familyId  String    @map("family_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  userAgent String    @map("user_agent") @db.VarChar(255)
  ipAddress String    @map("ip_address") @db.VarChar(255)
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
}

// =========
// AuditLog
// =========
model AuditLog {
  id               BigInt    @id @default(autoincrement()) @db.BigInt
  actorId          BigInt?   @map("actor_id") @db.BigInt
  organizationId   BigInt?   @map("organization_id") @db.BigInt
  projectId        BigInt?   @map("project_id") @db.BigInt
  environmentId    BigInt?   @map("environment_id") @db.BigInt
  entityType       String    @map("entity_type") @db.VarChar(100)
  entityId         String?   @map("entity_id") @db.VarChar(255)
  action           String    @db.VarChar(100)
  beforeState      Json?     @map("before_state") @db.JsonB
  afterState       Json?     @map("after_state") @db.JsonB
  ipAddress        String?   @map("ip_address") @db.VarChar(255)
  userAgent        String?   @map("user_agent") @db.VarChar(255)
  requestId        String?   @map("request_id") @db.VarChar(255)
  correlationId    String?   @map("correlation_id") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")

  actor          User?         @relation("AuditLogActor", fields: [actorId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  project        Project?      @relation(fields: [projectId], references: [id])
  environment    Environment?  @relation(fields: [environmentId], references: [id])

  @@index([actorId])
  @@index([organizationId])
  @@index([projectId])
  @@index([environmentId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==============
// ExceptionLog
// ==============
model ExceptionLog {
  id               BigInt    @id @default(autoincrement()) @db.BigInt
  actorId          BigInt?   @map("actor_id") @db.BigInt
  organizationId   BigInt?   @map("organization_id") @db.BigInt
  exceptionType    String    @map("exception_type") @db.VarChar(255)
  message          String    @db.Text
  stackTrace       String?   @map("stack_trace") @db.Text
  httpMethod       String?   @map("http_method") @db.VarChar(10)
  httpPath         String?   @map("http_path") @db.VarChar(500)
  httpStatusCode   Int?      @map("http_status_code")
  ipAddress        String?   @map("ip_address") @db.VarChar(255)
  userAgent        String?   @map("user_agent") @db.VarChar(255)
  requestId        String?   @map("request_id") @db.VarChar(255)
  correlationId    String?   @map("correlation_id") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")

  actor        User?        @relation("ExceptionLogActor", fields: [actorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([actorId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("exception_logs")
}
